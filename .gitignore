# ==================================================================
#   Experiment tracking
# ==================================================================
# We DO commit the frozen test split + CSV logs in runs/tmodel/ so the
# eval script is reproducible and the training-curve plots can be
# re-rendered from CSV. We only ignore the TensorBoard binary events.
runs/**/events.out.tfevents.*
runs/**/events.out.tfevents.*.v2

tensorboard/
wandb/
.wandb/
mlruns/
multirun/
outputs/
lightning_logs/
training_checkpoints/

# ==================================================================
#   Logs
# ==================================================================
*.log
eval.log
training.log

